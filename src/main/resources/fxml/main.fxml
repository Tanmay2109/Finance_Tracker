<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.finance.controller.MainController">

    <!-- LEFT MENU -->
    <left>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #1e293b;">
            <Label text="Finance Tracker"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

            <Button text="Dashboard" onAction="#showDashboard"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white;" />

            <Button text="Transactions" onAction="#showTransactions"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white;" />
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>