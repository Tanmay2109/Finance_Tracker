<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<VBox spacing="25"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finance.controller.DashboardController"
      style="-fx-padding: 25; -fx-background-color: #f4f6f9;">

    <!-- HEADER -->
    <Label text="Finance Dashboard"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <!-- CARDS -->
    <HBox spacing="20">

        <!-- Expense Card -->
        <VBox spacing="5"
              style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5,0,0,2);">
            <Label text="Total Expense"
                   style="-fx-text-fill: #777;"/>
            <Label fx:id="totalLabel"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Income Card -->
        <VBox spacing="5"
              style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5,0,0,2);">
            <Label text="Total Income"
                   style="-fx-text-fill: #777;"/>
            <Label fx:id="incomeLabel"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Balance Card -->
        <VBox spacing="5"
              style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5,0,0,2);">
            <Label text="Net Balance"
                   style="-fx-text-fill: #777;"/>
            <Label fx:id="balanceLabel"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>

    </HBox>

    <!-- CHARTS SECTION -->
    <HBox spacing="20">

        <!-- PIE CHART -->
        <VBox spacing="10"
              style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5,0,0,2);">
            <Label text="Expense by Category"
                   style="-fx-font-weight: bold;"/>
            <PieChart fx:id="pieChart" prefWidth="350" prefHeight="300"/>
        </VBox>

        <!-- BAR CHART -->
        <VBox spacing="10"
              style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5,0,0,2);">
            <Label text="Monthly Expenses"
                   style="-fx-font-weight: bold;"/>

            <BarChart fx:id="barChart" prefWidth="400" prefHeight="300">
                <xAxis>
                    <CategoryAxis label="Month"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Amount"/>
                </yAxis>
            </BarChart>

        </VBox>

    </HBox>

</VBox>